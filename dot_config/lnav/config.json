{
    "ui": {
        "theme": "monocai",
        "theme-defs": {
            "monocai": {
                "styles": {
                    "identifier": {
                        "color": "$white"
                    },
                    "text": {
                        "color": "#EFDFB5",
                        "background-color": "#282828"
                    },
                    "cursor-line": {
                        "color": "#fdecc0",
                        "background-color": "#928374",
                        "bold": false
                    },
                    "skewed-time": {
                        "color": "#EFDFB5"
                    }
                },
                "syntax-styles": {
                    "string": {
                        "color": "#EFDFB5"
                    },
                    "variable": {
                        "color": "#EFDFB5"
                    },
                    "file": {
                        "color": "#f6f6f6"
                    }
                }
            },
            "default": {
                "highlights": {
                    "mozart": {
                        "pattern": "(mozart-application|mozart-health-monitor|mozart-stream-proxy|mozart-fota-updater|mozart-airplay|mozart-audio-alsa-io|mozart-audio-identification|mozart-wac|mozart-audio-tv|mozart-out-powerlink|mozart-out-wisa|mozart-audio-pl|mozart-audio-wpl|mozart-voice-bando|mozart-voice|mozart-out-a2b|mozart-voice-aec|mozart-audio-spotify|mozart-audio-deezer|mozart-audio-tidal|mozart-cast-lite|mozart-audio-mic|mozart-audio-linein|mozart-audio-usb-in|mozart-audio-bluetooth|mozart-audio-netradio|mozart-audio-overlay|mozart-audio-local|mozart-audio-uristreamer|mozart-audio-spdif|mozart-audio-generator|mozart-audio-dlna|mozart-audio-netradio|mozart-audio-classics-adapter|mozart-audio-beolink|mozart-audio-speakerlink|mozart-audio-jack-router|mozart-jack-renderer|mozart-audio-mixer)",
                        "style": {
                            "color": "${semantic_highlight_color}"
                        }
                    },
                    "info": {
                        "pattern": "I:",
                        "style": {
                            "color": "#689d6a"
                        }
                    },
                    "warning": {
                        "pattern": "W:",
                        "style": {
                            "color": "#d79921"
                        }
                    },
                    "error": {
                        "pattern": "E:",
                        "style": {
                            "color": "#cc241d"
                        }
                    }
                }
            }
        }
    },
    "log": {
        "date-time": {
            "convert-zoned-to-local": false
        }
    }
}
